# Scraplus — proxy to Modal ASGI app (output of `modal deploy modal_app/app.py`)
# Base URL must match the Modal web endpoint root (no trailing slash).
SCRAPLUS_MODAL_BASE_URL=https://your-workspace--scraplus-scraplus-api.modal.run

# Shared secret: same value as Modal secret `scraplus-proxy-secret` key SCRAPLUS_PROXY_SECRET
SCRAPLUS_PROXY_SECRET=generate-a-long-random-string

# Modal: modal secret create scraplus-proxy-secret SCRAPLUS_PROXY_SECRET=your-value
# GitHub: rename repository to `scraplus` (Settings → General) and update git remote.
# Vercel: set SCRAPLUS_MODAL_BASE_URL + SCRAPLUS_PROXY_SECRET in Project → Environment Variables (Production & Preview).
